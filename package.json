    "serve": "node serve.mjs",
    "check:forms": "node scripts/check-forms.mjs",
    "check:placeholders": "node scripts/check-placeholders.mjs",
    "check:links": "node scripts/check-links.mjs",
    "check:seo": "node scripts/check-seo.mjs",
    "check:sitemap": "node scripts/check-sitemap.mjs",
    "check:voice": "node scripts/check-voice.mjs",
    "audit": "node scripts/audit.mjs",
    "images:hero": "node scripts/images-hero.mjs",
    "images:carousel": "node scripts/images-carousel.mjs",
    "images:portfolio": "node scripts/images-portfolio.mjs",
    "images:shoots": "node scripts/images-shoots.mjs",
    "images:all": "node scripts/images-hero.mjs && node scripts/images-carousel.mjs && node scripts/images-portfolio.mjs && node scripts/images-shoots.mjs",
    "ci:lighthouse": "lhci autorun",
    "ci:a11y": "pa11y-ci --config .pa11yci.json",
    "ci:links": "lychee --config lychee.toml --verbose '**/*.html' '**/*.md'",
    "ci:quality": "npm run ci:lighthouse && npm run ci:a11y"
